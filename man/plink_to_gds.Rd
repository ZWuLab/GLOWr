\tabular{lll}{
Numeric \tab Letter \tab Description \cr
1-22 \tab 1-22 \tab Autosomes \cr
23 \tab X \tab X chromosome \cr
24 \tab Y \tab Y chromosome \cr
25 \tab XY \tab Pseudo-autosomal region \cr
26 \tab MT \tab Mitochondrial
